import socket

def test_dns(query_name):
    resolver_addr = ('127.0.0.1', 5300)
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    
    try:
        print(f"Requesting IP for: {query_name}")
        sock.sendto(query_name.encode('utf-8'), resolver_addr)
        data, _ = sock.recvfrom(512)
        print(f"Response: {data.decode('utf-8')}")
    finally:
        sock.close()

if __name__ == "__main__":
    test_dns("www.cisco.test")
